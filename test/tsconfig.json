{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "outDir": "../out/test",
        "rootDir": "../",
        "sourceMap": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "types": [
            "jest",
            "node"
        ]
    },
    "include": [
        "./suite/**/*.ts",
        "../src/panels/**/*.ts",
        "../src/webview/config-panel/**/*.ts",
        "../src/services/**/*.ts",
        "../src/utils/**/*.ts"
    ]
}