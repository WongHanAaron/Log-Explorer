{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "outDir": "../out/test",
        "rootDir": "../",
        "baseUrl": "./",
        "sourceMap": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "moduleResolution": "node",
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "types": [
            "jest",
            "node",
            "sinon"
        ],
        "paths": {
            "vscode": [
                "test/unit/vscode"
            ]
        }
    },
    "include": [
        "./suite/**/*.ts",
        "./e2e/ui/**/*.ts",
        "../src/panels/**/*.ts",
        "../src/webview/config-panel/**/*.ts",
        "../src/services/**/*.ts",
        "../src/utils/**/*.ts",
        "../src/types/**/*.d.ts"
    ]
}