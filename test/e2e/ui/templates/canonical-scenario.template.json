{
    "schemaVersion": "2.0",
    "scenarioId": "panel-webview-example",
    "name": "Panel Webview Example",
    "priority": "P1",
    "tags": [
        "panel",
        "webview",
        "smoke"
    ],
    "preconditions": [
        "fixture:default-workspace"
    ],
    "steps": [
        {
            "index": 1,
            "action": "panel.open",
