{
  "schemaVersion": "2.0",
  "scenarioId": "filepath-config-smoke",
  "name": "Filepath config smoke",
  "priority": "P1",
  "tags": [
    "smoke",
    "config"
  ],
  "preconditions": [
    "fixture:default-workspace"
  ],
  "steps": [
    {
      "index": 1,
      "action": "webview.interact",
      "target": {},
      "assertions": [
        {
          "type": "host.outcome",
          "source": {
            "stateKey": "browserOpened"
          },
          "expected": true
        }
      ]
    },
    {
      "index": 2,
      "action": "webview.interact",
      "target": {
        "url": "file://{{fixturePath}}/ui/debug-harness.html"
      },
      "assertions": [
        {
          "type": "webview.visible",
          "source": {
            "selector": "#app"
          },
          "expected": true
        }
      ]
    },
    {
      "index": 3,
      "action": "webview.interact",
      "target": {
        "selector": "#open-config"
      },
      "assertions": [
        {
          "type": "webview.textContains",
          "source": {
            "selector": "#status"
          },
          "expected": "Config opened"
        }
      ]
    }
  ]
}
