{
  "schemaVersion": "2.0",
  "scenarioId": "output-verification-smoke",
  "name": "Output verification smoke",
  "priority": "P1",
  "tags": [
    "smoke",
    "output"
  ],
  "preconditions": [
    "fixture:default-workspace"
  ],
  "steps": [
    {
      "index": 1,
      "action": "webview.interact",
      "target": {},
      "assertions": [
        {
          "type": "host.outcome",
          "source": {
            "stateKey": "browserOpened"
          },
          "expected": true
        }
      ]
    },
    {
      "index": 2,
      "action": "webview.interact",
      "target": {
        "url": "file://{{fixturePath}}/ui/debug-harness.html"
      },
      "assertions": [
        {
          "type": "webview.visible",
          "source": {
            "selector": "#filepath"
          },
          "expected": true
        }
      ]
    },
    {
      "index": 3,
      "action": "webview.interact",
      "target": {
        "selector": "#filepath"
      },
      "input": "C:/logs/app.log",
      "assertions": [
        {
          "type": "webview.visible",
          "source": {
            "selector": "#save-path"
          },
          "expected": true
        }
      ]
    },
    {
      "index": 4,
      "action": "webview.interact",
      "target": {
        "selector": "#save-path"
      },
      "assertions": [
        {
          "type": "webview.textEquals",
          "source": {
            "selector": "#savedPath"
          },
          "expected": "C:/logs/app.log"
        }
      ]
    }
  ]
}
