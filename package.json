{
    "name": "logexplorer",
    "displayName": "LogExplorer",
    "description": "A VSCode extension for exploring and analyzing log files",
    "version": "0.1.0",
    "publisher": "logexplorer",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "main": "./dist/extension.js",
    "activationEvents": [],
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "logexplorer-container",
                    "title": "LogExplorer",
                    "icon": "resources/icons/logexplorer.svg"
                }
            ]
        },
        "views": {
            "logexplorer-container": [
                {
                    "type": "webview",
                    "id": "logexplorer.panel",
                    "name": "Log Explorer"
                }
            ]
        },
        "commands": [
            {
                "command": "logexplorer.showPanel",
                "title": "Show Panel",
                "category": "LogExplorer"
            }
        ]
    },
    "scripts": {
        "build": "node esbuild.mjs",
        "watch": "node esbuild.mjs --watch",
        "pretest": "npm run build",
        "test": "vscode-test",
        "package": "vsce package",
        "vscode:prepublish": "node esbuild.mjs --production"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.3.2",
        "@types/vscode": "^1.109.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "esbuild": "^0.27.3",
        "mocha": "^11.7.5",
        "typescript": "^5.9.3"
    }
}