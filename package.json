{
    "name": "logexplorer",
    "displayName": "LogExplorer",
    "description": "A VSCode extension for exploring and analyzing log files",
    "version": "0.2.0",
    "publisher": "logexplorer",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "main": "./dist/extension.js",
    "activationEvents": [],
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "logexplorer-container",
                    "title": "LogExplorer",
                    "icon": "resources/icons/logexplorer.svg"
                }
            ],
            "panel": [
                {
                    "id": "logexplorer-bottom",
                    "title": "Log Explorer",
                    "icon": "resources/icons/logexplorer.svg"
                }
            ]
        },
        "views": {
            "logexplorer-container": [
                {
                    "type": "webview",
                    "id": "logexplorer.panel",
                    "name": "Log Explorer"
                },
                {
                    "type": "webview",
                    "id": "logexplorer.sessionTools",
                    "name": "Session Tools"
                },
                {
                    "type": "webview",
                    "id": "logexplorer.logDetails",
                    "name": "Log Details"
                }
            ],
            "logexplorer-bottom": [
                {
                    "type": "webview",
                    "id": "logexplorer.searchResults",
                    "name": "Search Results"
                }
            ]
        },
        "commands": [
            {
                "command": "logexplorer.showPanel",
                "title": "Show Panel",
                "category": "LogExplorer"
            },
            {
                "command": "logexplorer.newSession",
                "title": "New Session",
                "category": "Log Explorer"
            },
            {
                "command": "logexplorer.editLogFileSourceConfig",
                "title": "Edit Log File Source Config",
                "category": "Log Explorer"
            },
            {
                "command": "logexplorer.editFileLogLineConfig",
                "title": "Edit File Log Line Config",
                "category": "Log Explorer"
            },
            {
                "command": "logexplorer.editSessionTemplates",
                "title": "Edit Session Templates",
                "category": "Log Explorer"
            },
            {
                "command": "logexplorer.setupWorkspace",
                "title": "Setup New Workspace",
                "category": "Log Explorer"
            },
            {
                "command": "logexplorer.gettingStarted",
                "title": "Getting Started",
                "category": "Log Explorer"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "logexplorer.showPanel",
                    "when": "workspaceFolderCount > 0 && logexplorer.workspaceInitialized"
                },
                {
                    "command": "logexplorer.newSession",
                    "when": "workspaceFolderCount > 0 && logexplorer.workspaceInitialized"
                },
                {
                    "command": "logexplorer.editLogFileSourceConfig",
                    "when": "workspaceFolderCount > 0 && logexplorer.workspaceInitialized"
                },
                {
                    "command": "logexplorer.editFileLogLineConfig",
                    "when": "workspaceFolderCount > 0 && logexplorer.workspaceInitialized"
                },
                {
                    "command": "logexplorer.editSessionTemplates",
                    "when": "workspaceFolderCount > 0 && logexplorer.workspaceInitialized"
                },
                {
                    "command": "logexplorer.setupWorkspace",
                    "when": "workspaceFolderCount > 0 && !logexplorer.workspaceInitialized"
                }
            ]
        }
    },
    "scripts": {
        "build": "node esbuild.mjs",
        "watch": "node esbuild.mjs --watch",
        "pretest": "npm run build && tsc -p test/tsconfig.json",
        "test": "vscode-test",
        "package": "vsce package --allow-missing-repository",
        "package:local": "node scripts/package-local.mjs",
        "install:local": "node scripts/install-local.mjs",
        "release:local": "npm run package:local && npm run install:local",
        "test:kibana": "npm run pretest && node scripts/run-kibana-tests.js",
        "loggen": "ts-node tools/loggen.ts",
        "build:tools": "echo \"no build needed\"",
        "test:e2e-data": "set \"NODE_OPTIONS=--loader ts-node/esm\" && mocha test/unit/**/*.ts test/e2e/**/*.ts",
        "compose:up": "bash scripts/compose.sh up",
        "compose:down": "bash scripts/compose.sh down",
        "compose:ps": "bash scripts/compose.sh ps",
        "vscode:prepublish": "node esbuild.mjs --production"
    },
    "devDependencies": {
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.3.2",
        "@types/vscode": "^1.85.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.7.1",
        "esbuild": "^0.27.3",
        "glob": "^13.0.6",
        "mocha": "^11.7.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}