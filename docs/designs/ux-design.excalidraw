      "updated": 1772325919240,
      "link": null,
      "locked": false,
      "text": "File Naming structure\n- Convention based file name:\n  - file(?<date:yyyymmdd>\\d\\d\\d\\d)_(?<enumeration>\\d?)\\.txt\n  - (?<date:yyyymmdd>\\d\\d\\d\\d\\d\\d\\d\\d)(?<time:HHMMss>\\d\\d\\d\\d\\d\\d\\d\\d) \\[(?<thread>\\d+)\\].txt\n\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "File Naming structure\n- Convention based file name:\n  - file(?<date:yyyymmdd>\\d\\d\\d\\d)_(?<enumeration>\\d?)\\.txt\n  - (?<date:yyyymmdd>\\d\\d\\d\\d\\d\\d\\d\\d)(?<time:HHMMss>\\d\\d\\d\\d\\d\\d\\d\\d) \\[(?<thread>\\d+)\\].txt\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
