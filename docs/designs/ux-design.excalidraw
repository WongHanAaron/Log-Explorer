      "updated": 1772315962479,
      "link": null,
      "locked": false,
      "text": "Required Things:\n- Setting the source access\n- Access\n   - SFTP\n   - Kubernetes Pod\n\n- Ex: \n   - file path\n   - file include/exclude\n   - date time extractor\n\nLog Property Attribute\n- DateTime extraction\n- Log-Level extraction\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Required Things:\n- Setting the source access\n- Access\n   - SFTP\n   - Kubernetes Pod\n\n- Ex: \n   - file path\n   - file include/exclude\n   - date time extractor\n\nLog Property Attribute\n- DateTime extraction\n- Log-Level extraction\n",
      "autoResize": true,
      "lineHeight": 1.25
